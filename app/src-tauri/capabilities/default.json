{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main editor and physics paint windows",
  "windows": ["main", "efx-physic-paint"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-destroy",
    "core:app:default",
    "core:path:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "fs:default",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:scope-appdata-recursive",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    },
    "notification:default"
  ]
}
