{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "EFX Motion Editor",
  "version": "0.1.0",
  "identifier": "com.efxlab.motion-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "resources": ["resources/*"]
  },
  "app": {
    "windows": [
      {
        "title": "EFX Motion Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "backgroundColor": "#0F0F0F"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://*; connect-src 'self' ipc: http://ipc.localhost https://*; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}
